# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Luxe"

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://user:password@localhost:5432/luxe_commerce?schema=public"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-a-long-random-string"

# --- OAuth providers (optional) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# --- Stripe (international card payments) ---
# https://dashboard.stripe.com → test mode
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- Byl (Mongolian payments) ---
# https://byl.mn — tokens нь https://byl.mn/user/api-tokens
# Хоосон үлдээвэл checkout нь демо горимоор шууд PAID болгоно.
BYL_PROJECT_ID=""
BYL_TOKEN=""
# Byl dashboard → Project → Webhook → secret-ийг хуулна
BYL_WEBHOOK_SECRET=""

# --- Email (Resend) ---
# https://resend.com — үнэгүй tier, ~100 имэйл/өдөр.
# Тохируулаагүй бол захиалгын мэдэгдэл console-руу буцна.
RESEND_API_KEY=""
EMAIL_FROM="Luxe <onboarding@resend.dev>"

# --- Misc ---
DEFAULT_CURRENCY="MNT"
