# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Luxe"

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://user:password@localhost:5432/luxe_commerce?schema=public"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-a-long-random-string"

# --- OAuth providers (optional) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# --- Stripe ---
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- Email (Resend) ---
# https://resend.com — үнэгүй tier, ~100 имэйл/өдөр.
# Тохируулаагүй бол захиалгын мэдэгдэл console-руу буцна.
RESEND_API_KEY=""
EMAIL_FROM="Luxe <onboarding@resend.dev>"

# --- Misc ---
DEFAULT_CURRENCY="MNT"
