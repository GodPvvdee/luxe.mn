# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Luxe"

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://user:password@localhost:5432/luxe_commerce?schema=public"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-a-long-random-string"

# --- OAuth providers (optional) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# --- Stripe (international card payments) ---
# https://dashboard.stripe.com → test mode
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- QPay (Mongolian QR payments) ---
# https://developer.qpay.mn — merchant дансаа авах хэрэгтэй.
# Бүгдийг хоосон үлдээвэл checkout нь demo placeholder QR-р ажиллана.
QPAY_USERNAME=""
QPAY_PASSWORD=""
QPAY_INVOICE_CODE=""
# Өгөгдмөл sandbox URL — production-д "https://merchant.qpay.mn/v2" болго.
# QPAY_BASE_URL="https://merchant-sandbox.qpay.mn/v2"

# --- Email (Resend) ---
# https://resend.com — үнэгүй tier, ~100 имэйл/өдөр.
# Тохируулаагүй бол захиалгын мэдэгдэл console-руу буцна.
RESEND_API_KEY=""
EMAIL_FROM="Luxe <onboarding@resend.dev>"

# --- Misc ---
DEFAULT_CURRENCY="MNT"
